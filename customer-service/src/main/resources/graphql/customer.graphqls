type Customer {
    id: ID!
    email: String!
    phone: String!
    userName: String!
    firstName: String!
    lastName: String!
    country: String!
    zipcode: String!
    city: String!
    street: String!
    building: String!
    apartment: String
    status: String!
    loyaltyPoints: Int!
    deleted: Boolean!
}

type Query {
    customer(id: ID!): Customer
    customers: [Customer!]!
    customerByEmail(email: String!): Customer
    customerByUserName(userName: String!): Customer
}